prefix_rule(pattern=["gh", "api"], decision="allow")
prefix_rule(pattern=["npx", "playwright", "test"], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "sed -n '1,220p' \"$HOME/.codex/AGENTS.md\""], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "rm -f \"$HOME/.codex/rules/default.rules.bak.20260407140205\""], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "cp /tmp/codex-skill-build/review/scripts/review-setup.sh \"$HOME/.codex/skills/review/scripts/review-setup.sh\" && chmod +x \"$HOME/.codex/skills/review/scripts/review-setup.sh\""], decision="allow")
prefix_rule(pattern=["git", "ls-remote", "--heads", "https://github.com/aashrayap/dot-codex.git"], decision="allow")
prefix_rule(pattern=["gh", "auth", "status"], decision="allow")
prefix_rule(pattern=["gh", "repo", "view", "aashrayap/dot-codex"], decision="allow")
prefix_rule(pattern=["git", "checkout", "--theirs"], decision="allow")
prefix_rule(pattern=["git", "add"], decision="allow")
prefix_rule(pattern=["/bin/zsh", "-lc", "GIT_EDITOR=true git rebase --continue"], decision="allow")
