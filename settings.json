{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "mcp__ide__getDiagnostics",
      "mcp__playwright-extension__browser_navigate",
      "mcp__playwright-extension__browser_take_screenshot",
      "mcp__claude_ai_Context7__resolve-library-id",
      "WebFetch(domain:docs.expo.dev)",
      "mcp__ios-simulator__get_booted_sim_id",
      "mcp__ios-simulator__screenshot",
      "mcp__ios-simulator__ui_describe_all",
      "mcp__ios-simulator__ui_tap",
      "mcp__ios-simulator__ui_swipe",
      "Bash(~/.claude/skills/spec-new-feature/scripts/new-feature-setup.sh:*)",
      "Bash(~/.claude/skills/review/scripts/review-setup.sh:*)",
      "Bash(~/.claude/skills/projects/scripts/projects-setup.sh:*)",
      "mcp__figma-desktop__get_design_context",
      "mcp__figma-desktop__get_screenshot",
      "mcp__claude_ai_Notion__notion-fetch",
      "Bash(~/.claude/skills/daily-review/scripts/daily-review-setup.py:*)",
      "Bash(~/.claude/skills/daily-review/scripts/fetch-last-day-sessions.py:*)",
      "Bash(~/.claude/skills/daily-review/scripts/inspect-session.py:*)",
      "mcp__pencil"
    ],
    "defaultMode": "default"
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline-enhanced.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "medium",
  "autoMemoryEnabled": false,
  "autoDreamEnabled": false,
  "showThinkingSummaries": true
}