{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "model": "opus[1m]",
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cmux notify --title \"Claude Code\" --body \"$CLAUDE_NOTIFICATION\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude-code-docs/claude-docs-helper.sh hook-check"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/check-harness-update.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline-enhanced.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "agent-sdk-dev@claude-code-plugins": true,
    "code-review@claude-code-plugins": true,
    "commit-commands@claude-code-plugins": true,
    "dvn-arrow-updater@dvn-arrow-plugins": true,
    "dvn-arrow-claude@dvn-arrow-plugins": true,
    "superpowers@superpowers-marketplace": true,
    "devon-marketplace-updater@devon-agentic-coding-plugins": true,
    "devon-standards@devon-agentic-coding-plugins": true,
    "devon-snowflake@devon-agentic-coding-plugins": true,
    "imessage@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "autoDreamEnabled": true,
  "skipDangerousModePermissionPrompt": true
}
